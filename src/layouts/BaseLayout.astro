---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import { SITE, absoluteUrl } from "../config/site";
import { defaultLocale, locales } from "../i18n/ui";

interface Props {
  title: string;
  description: string;
  /** OG/Twitter náhledový obrázek (absolutní nebo relativní cesta). */
  image?: string;
  /** OG typ — "website" (default) nebo "article". */
  ogType?: "website" | "article";
  /** Zabránit indexaci (např. utility stránky). */
  noindex?: boolean;
  /** Structured data k vložení. */
  jsonld?: Record<string, unknown> | Record<string, unknown>[];
  /** Hlavička transparentní přes hero (default true pro stránky s tmavým hero). */
  transparentHeader?: boolean;
}

const {
  title,
  description,
  image = "/og-default.jpg",
  ogType = "website",
  noindex = false,
  jsonld,
  transparentHeader = true,
} = Astro.props;

const lang = Astro.currentLocale ?? defaultLocale;
const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const ogImage = image.startsWith("http") ? image : absoluteUrl(image);

// hreflang alternativy — pro každý nakonfigurovaný jazyk.
const path = Astro.url.pathname;
const alternates = locales.map((loc) => ({
  loc,
  href:
    loc === defaultLocale
      ? new URL(path, SITE.url).toString()
      : new URL(`/${loc}${path}`, SITE.url).toString(),
}));

const ga4 = SITE.ga4Id && SITE.ga4Id !== "G-XXXXXXXXXX" ? SITE.ga4Id : null;

// Vždy přítomné Organization + WebSite structured data (sitelinks search box).
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.name,
  url: SITE.url,
  logo: absoluteUrl("/logo.png"),
  sameAs: [
    SITE.social.instagram,
    SITE.social.facebook,
    SITE.social.pinterest,
    SITE.social.tiktok,
  ],
};
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE.name,
  url: SITE.url,
  inLanguage: "cs-CZ",
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- hreflang -->
    {
      alternates.map((a) => (
        <link rel="alternate" hreflang={a.loc} href={a.href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={SITE.url + path} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="cs_CZ" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts (CDN — self-host při produkci pro rychlost) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant:wght@500;600;700&family=Jost:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap"
    />

    <!-- Structured data -->
    <JsonLd schema={orgSchema} />
    <JsonLd schema={websiteSchema} />
    {jsonld && <JsonLd schema={jsonld} />}

    <!-- GA4 (načte se jen s reálným measurement ID v src/config/site.ts) -->
    {
      ga4 && (
        <>
          <script
            is:inline
            src={`https://www.googletagmanager.com/gtag/js?id=${ga4}`}
            async
          />
          <script is:inline define:vars={{ ga4 }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", ga4);
          </script>
        </>
      )
    }
  </head>
  <body>
    <Header transparent={transparentHeader} />
    <slot />
    <Footer />
  </body>
</html>
