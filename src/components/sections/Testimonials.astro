---
import SectionIntro from "./SectionIntro.astro";

type Story = {
  quote: string;
  coupleName: string;
  meta: string;
  image: string;
  highlight?: boolean;
};

const stories: Story[] = [
  {
    quote:
      "WeMarry doporučuji. Sdílela jsem ho společně se svou koordinátorkou a mohly jsme tak obě zaznamenávat poznámky k svatebnímu dni i rozvržení stolů. Elektronické pozvánky se moc líbily i našim hostům a možnost nahrát fotky přes QR kód do sdíleného alba je úžasná!",
    coupleName: "Frantovi",
    meta: "Svatba pro 40 hostů",
    image: "/img/reviews/frantovi.jpg",
  },
  {
    quote:
      "S WeMarry jsme byli opravdu velmi spokojeni. Oceňuji krásnou a přehlednou grafiku, jednoduché ovládání a také možnost mít web ve dvou jazycích. Super byla funkce rozpočtu, fungoval i zasedací pořádek a nadchly nás také online pozvánky.",
    coupleName: "Čáky",
    meta: "Svatba pro 100 hostů",
    image: "/img/reviews/caky.jpg",
    highlight: true,
  },
  {
    quote:
      "V dnešní době je svatební web téměř nutnost — nejefektivnější a nejrychlejší způsob, jak oslovit všechny hosty. Rozhodli jsme se pro WeMarry, protože se nám nejvíc líbil jejich design, šablony i celkové uživatelské prostředí.",
    coupleName: "Macurovi",
    meta: "Svatba pro 120 hostů",
    image: "/img/reviews/macurovi.jpg",
  },
];
---

<section class="bg-cream py-20 md:py-28 lg:py-32">
  <div class="container-site">
    <SectionIntro
      eyebrow="Příběhy"
      title="Příběhy našich svatebčanů"
      subtitle="Přes 3 000 českých párů si s WeMarry naplánovalo svatbu svých snů. Tady jsou tři z nich."
    />

    <div class="mt-14 grid grid-cols-1 gap-6 lg:mt-20 lg:grid-cols-3 lg:gap-8">
      {
        stories.map((story) => (
          <article
            class:list={[
              "flex flex-col overflow-hidden rounded-card border shadow-card transition-shadow hover:shadow-prominent",
              story.highlight
                ? "border-primary/20 bg-white lg:-translate-y-4"
                : "border-beige-border bg-white",
            ]}
          >
            <div class="relative aspect-[4/3] w-full overflow-hidden">
              <img src={story.image} alt={`Svatba — ${story.coupleName}`} loading="lazy" class="absolute inset-0 size-full object-cover" />
              <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
            </div>

            <div class="flex flex-1 flex-col gap-5 p-8 md:p-10">
              <svg viewBox="0 0 32 24" class="size-7 text-primary/70" fill="currentColor" aria-hidden="true">
                <path d="M0 24V12C0 5.4 4.8 0 12 0v4c-4 .8-6.4 3.6-6.4 8H12v12H0zm20 0V12c0-6.6 4.8-12 12-12v4c-4 .8-6.4 3.6-6.4 8H32v12H20z"></path>
              </svg>
              <blockquote class="font-serif text-h4 italic leading-snug text-ink">
                „{story.quote}"
              </blockquote>

              <div class="mt-auto flex items-center justify-between pt-4">
                <p class="font-serif text-body text-ink">{story.coupleName}</p>
                <p class="text-tiny uppercase tracking-cta text-primary">{story.meta}</p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
