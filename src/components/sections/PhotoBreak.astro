---
import { SITE } from "../../config/site";
---

<section class="relative isolate overflow-hidden">
  <div aria-hidden="true" class="absolute inset-0 -z-10 bg-gradient-to-r from-[#5a4a42] via-[#8a7367] to-[#c9a796]"></div>
  <div aria-hidden="true" class="absolute inset-0 -z-10 bg-gradient-to-b from-black/35 to-black/50"></div>

  <div class="container-site flex min-h-[540px] flex-col justify-center py-20 md:min-h-[620px] md:py-28 lg:flex-row lg:items-center lg:gap-20">
    <div class="max-w-xl text-white lg:flex-1">
      <p class="text-tiny uppercase tracking-cta text-white/80">Svatební web a RSVP</p>
      <h2 class="mt-4 font-serif text-hero-sm md:text-hero">
        Ušetřete si hromadu telefonátů a neustálého vysvětlování.
      </h2>
      <p class="mt-6 text-body text-white/85">
        Vytvořte si během pár minut svatební web s RSVP formulářem i ve více
        jazycích. Pošlete hostům všechny informace a nechte aplikaci, aby sama
        sesbírala odpovědi.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a href={SITE.app.signup} class="btn-primary">Vytvořit svatební web</a>
        <a href="/sablony" class="text-micro uppercase tracking-cta text-white hover:text-white/80">
          Prohlédnout šablony →
        </a>
      </div>
    </div>

    <!-- Fake phone mockup -->
    <div class="mt-12 flex justify-center lg:mt-0 lg:flex-1">
      <div class="relative w-[240px] h-[480px] rounded-[48px] bg-gradient-to-br from-white/95 to-cream shadow-prominent p-3">
        <div class="size-full rounded-[36px] bg-gradient-to-br from-cream to-beige-light p-4 space-y-3">
          <div class="mx-auto mt-2 h-1 w-16 rounded-full bg-ink/10"></div>
          <div class="aspect-[4/3] rounded-card bg-gradient-to-br from-warm-peach to-sage/30"></div>
          <div class="space-y-2">
            <div class="h-3 w-3/4 rounded-full bg-ink/15"></div>
            <div class="h-2 w-full rounded-full bg-ink/8"></div>
            <div class="h-2 w-5/6 rounded-full bg-ink/8"></div>
          </div>
          <div class="flex items-center justify-center h-10 rounded-pill bg-primary">
            <span class="text-tiny uppercase tracking-cta text-white">Potvrdit účast</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
