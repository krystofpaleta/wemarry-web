---
import SectionIntro from "./SectionIntro.astro";
import { SITE } from "../../config/site";

// SVG donut "80% Rozpočet"
const size = 180;
const stroke = 14;
const radius = (size - stroke) / 2;
const circumference = 2 * Math.PI * radius;
const progress = 0.8;
const dashOffset = circumference * (1 - progress);

const checklistItems = [
  { label: "Vybrat místo obřadu", done: true },
  { label: "Zařídit květiny", done: false },
  { label: "Vybrat prstýnky", done: false },
  { label: "Rozeslat pozvánky", done: true },
];
---

<section class="bg-white py-20 md:py-28 lg:py-32">
  <div class="container-site">
    <SectionIntro
      eyebrow="Plánuj svatbu s námi"
      title="Vše, co láska a svatba vyžadují, na jednom místě"
      subtitle="Od první vize až po poslední děkovku. WeMarry vás provede celou svatbou tak, aby byla přesně taková, jakou jste si ji vysnili."
    />

    <div class="mt-14 grid grid-cols-1 gap-6 lg:mt-20 lg:grid-cols-2 lg:gap-6">
      <!-- Levý sloupec -->
      <div class="flex flex-col gap-6">
        <!-- Tall: Zorganizovaní hosté -->
        <article class="relative flex flex-col gap-6 overflow-hidden rounded-card border border-beige-light bg-cream p-8 md:p-10 min-h-[420px] lg:min-h-[600px]">
          <header class="flex flex-col gap-3">
            <h3 class="font-serif text-h2 text-ink">Zorganizovaní hosté</h3>
            <p class="text-body text-ink-body">Svatební web, online pozvánky, detaily o každém hostovi a zasedací pořádek zajistí, že vy i hosté máte veškeré důležité informace na jednom místě.</p>
          </header>
          <div class="flex-1 min-h-[220px] relative">
            <div class="absolute inset-0 flex items-end justify-center overflow-hidden">
              <div class="relative w-[220px] h-[280px] rounded-[32px] bg-gradient-to-br from-warm-peach to-beige shadow-prominent rotate-[-6deg]">
                <div class="absolute -left-6 top-10 w-[180px] rounded-card-sm bg-white shadow-card p-4 space-y-2">
                  <div class="flex items-center gap-2">
                    <div class="size-8 rounded-full bg-sage/40"></div>
                    <div class="flex-1 space-y-1.5">
                      <div class="h-2 w-20 rounded-full bg-ink/10"></div>
                      <div class="h-2 w-14 rounded-full bg-ink/5"></div>
                    </div>
                  </div>
                  <div class="h-1.5 w-full rounded-full bg-ink/5"></div>
                  <div class="h-1.5 w-3/4 rounded-full bg-ink/5"></div>
                </div>
              </div>
            </div>
          </div>
        </article>

        <!-- Short: Čistá hlava (checklist) -->
        <article class="flex flex-col gap-5 rounded-card border border-beige-border bg-cream p-8 md:flex-row md:items-center md:gap-8 md:p-10 min-h-[260px]">
          <div class="flex-1">
            <h3 class="font-serif text-h2 text-ink">Čistá hlava a klid na duši</h3>
            <p class="mt-3 text-body text-ink-body">Checklist od zkušené koordinátorky zaručí, že vám nic neunikne. Odškrtávejte si úkoly postupně, jak se blíží velký den.</p>
          </div>
          <div class="shrink-0 flex items-center justify-center md:w-48 md:h-48">
            <div class="flex w-full flex-col gap-2">
              {
                checklistItems.map((item) => (
                  <div class="flex items-center gap-2 rounded-pill border border-beige-light bg-white px-3 py-2">
                    <span class:list={["flex size-5 shrink-0 items-center justify-center rounded-full", item.done ? "bg-sage" : "border border-neutral-gray bg-white"]} aria-hidden="true">
                      {item.done && (
                        <svg viewBox="0 0 12 12" class="size-3 text-white" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 6.5L5 9L10 3.5"></path></svg>
                      )}
                    </span>
                    <span class:list={["text-small", item.done ? "text-ink-soft line-through" : "text-ink-body"]}>{item.label}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </article>
      </div>

      <!-- Pravý sloupec -->
      <div class="flex flex-col gap-6">
        <!-- Short: Náklady (donut) -->
        <article class="flex flex-col gap-5 rounded-card border border-beige-border bg-cream p-8 md:flex-row md:items-center md:gap-8 md:p-10 min-h-[260px]">
          <div class="flex-1">
            <h3 class="font-serif text-h2 text-ink">Náklady pod kontrolou</h3>
            <p class="mt-3 text-body text-ink-body">Pohlídejte si výdaje do poslední koruny. Mějte přehled, co kolik stálo, kde je záloha a kde zbývá co zaplatit.</p>
          </div>
          <div class="shrink-0 flex items-center justify-center md:w-48 md:h-48">
            <div class="flex size-44 items-center justify-center rounded-full bg-white shadow-soft md:size-48" aria-label="80 % rozpočtu utraceno">
              <div class="relative" style={`width:${size}px;height:${size}px`}>
                <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`} class="-rotate-90" aria-hidden="true">
                  <circle cx={size / 2} cy={size / 2} r={radius} stroke="currentColor" class="text-ink/5" stroke-width={stroke} fill="none"></circle>
                  <circle cx={size / 2} cy={size / 2} r={radius} stroke="currentColor" class="text-primary" stroke-width={stroke} stroke-dasharray={circumference} stroke-dashoffset={dashOffset} stroke-linecap="round" fill="none"></circle>
                </svg>
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                  <span class="font-serif text-hero text-ink leading-none">80%</span>
                  <span class="mt-1.5 text-tiny uppercase tracking-label text-ink-soft">Rozpočet</span>
                </div>
              </div>
            </div>
          </div>
        </article>

        <!-- Tall: Ověření dodavatelé (tablet) -->
        <article class="relative flex flex-col gap-6 overflow-hidden rounded-card border border-beige-light bg-cream p-8 md:p-10 min-h-[420px] lg:min-h-[600px]">
          <header class="flex flex-col gap-3">
            <h3 class="font-serif text-h2 text-ink">Ověření dodavatelé a inspirace</h3>
            <p class="text-body text-ink-body">Katalog kvalitních fotografů, floristek, designérů a koordinátorek. Nechte se inspirovat a vyberte si tým, který vaší svatbě sluší.</p>
          </header>
          <div class="flex-1 min-h-[220px] relative">
            <div class="absolute inset-0 flex items-end justify-center overflow-hidden">
              <div class="relative w-[320px] h-[220px] rounded-card bg-gradient-to-br from-beige-light to-warm-peach shadow-prominent rotate-[-4deg] p-4 space-y-3">
                <div class="h-4 w-28 rounded-full bg-ink/10"></div>
                <div class="grid grid-cols-3 gap-2">
                  {[1, 2, 3].map(() => (
                    <div class="aspect-[4/5] rounded-card-sm bg-white/70 shadow-card">
                      <div class="size-full rounded-card-sm bg-gradient-to-br from-warm-peach to-beige opacity-60"></div>
                    </div>
                  ))}
                </div>
                <div class="h-2 w-3/4 rounded-full bg-ink/10"></div>
                <div class="h-2 w-1/2 rounded-full bg-ink/5"></div>
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>

    <!-- Footer CTA pod kartami -->
    <div class="mt-14 flex flex-col items-center gap-4 lg:mt-20">
      <p class="text-body text-ink-muted text-center">Vše, co ke svatbě potřebujete — v jedné aplikaci.</p>
      <a href={SITE.app.signup} class="btn-primary">Vyzkoušet zdarma</a>
    </div>
  </div>
</section>
