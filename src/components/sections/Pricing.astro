---
import { SITE } from "../../config/site";

const weMarryItems = [
  "Svatební web s detailním RSVP",
  "Doporučení dodavatelů na míru ZDARMA",
  "Checklist úkolů",
  "Kalkulačka nákladů",
  "Zasedací pořádek",
  "Sdílená fotogalerie",
  "30 dní garance vrácení peněz",
];

const othersItems = [
  "Spousta spáleného času",
  "Vše na jednom místě",
  "Neomezená zkušební doba",
  "Opravdu jednoduché ovládání",
  "Vlastní doména např. novakovi.cz",
  "Neustálý vývoj",
];

// Odhad ušetřeného času (balíček zahrnuje web, RSVP i galerii).
const savesHours = 30;
const savesBreakdown = [
  { label: "Odpovídání na opakované dotazy hostů", hours: 8 },
  { label: "Obvolávání hostů kvůli potvrzení účasti", hours: 8 },
  { label: "Sledování a urgování odpovědí", hours: 4 },
  { label: "Finální seznam pro dodavatele a zasedací pořádek", hours: 2 },
  { label: "Aktualizace informací a rozeslání změn", hours: 2 },
  { label: "Sbírání a třídění fotek od hostů", hours: 4 },
  { label: "Založení a sdílení fotoalba", hours: 2 },
];
const savesNote = "Odhad pro průměrnou svatbu ~60 hostů.";
---

<section class="relative isolate overflow-hidden py-20 md:py-28 lg:py-32">
  <div aria-hidden="true" class="absolute inset-0 -z-10 bg-gradient-to-b from-warm-peach/30 via-cream to-white"></div>

  <div class="container-site">
    <div class="mx-auto grid grid-cols-1 gap-6 lg:grid-cols-2 lg:gap-8">
      <!-- WeMarry card -->
      <article class="relative flex flex-col gap-8 rounded-card bg-white p-8 shadow-prominent md:p-10 lg:p-12">
        <header class="flex flex-col gap-4">
          <h3 class="font-serif text-h2 text-ink">WeMarry</h3>
          <p class="text-body text-ink-muted">nejdříve zdarma, při zveřejnění webu za</p>
        </header>

        <div class="flex items-start">
          <span class="font-serif text-hero text-ink leading-none md:text-hero-xl">1490</span>
          <span class="ml-1 mt-2 text-h4 text-ink md:mt-3">Kč</span>
        </div>
        <p class="-mt-4 text-body text-ink-muted">jednorázově</p>

        {/* Ušetřený čas + rozklad */}
        <details class="group rounded-mini bg-cream px-4 py-3">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-2 text-small text-ink-body">
            <span class="flex items-center gap-2">
              <svg viewBox="0 0 24 24" class="size-4 text-primary" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg>
              Ušetří vám <strong class="font-semibold text-ink">~{savesHours} h</strong> práce
            </span>
            <span class="text-tiny uppercase tracking-cta text-primary transition-transform group-open:rotate-45">+</span>
          </summary>
          <ul class="mt-3 flex flex-col gap-1.5 border-t border-beige-border pt-3">
            {
              savesBreakdown.map((row) => (
                <li class="flex items-center justify-between gap-3 text-tiny text-ink-muted">
                  <span>{row.label}</span>
                  <span class="shrink-0 text-ink-soft">~{row.hours} h</span>
                </li>
              ))
            }
            <li class="mt-1 text-tiny text-ink-light">{savesNote}</li>
          </ul>
        </details>

        <ul class="mt-2 flex flex-col gap-4">
          {
            weMarryItems.map((label) => (
              <li class="flex items-start gap-3">
                <span aria-hidden="true" class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full border-2 border-primary/70 bg-white">
                  <svg viewBox="0 0 14 14" class="size-3.5 text-primary" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7.5L6 10.5L11 4"></path></svg>
                </span>
                <span class="text-body text-ink-body">{label}</span>
              </li>
            ))
          }
        </ul>

        <a href={SITE.app.signup} class="btn-primary mt-auto w-full px-8 py-4">Vyzkoušet zdarma</a>
      </article>

      <!-- Ostatní řešení card -->
      <article class="relative flex flex-col gap-8 rounded-card bg-white p-8 shadow-card md:p-10 lg:p-12">
        <header class="flex flex-col gap-4">
          <h3 class="font-serif text-h2 text-ink">Ostatní řešení</h3>
          <p class="text-body text-ink-muted">ve srovnání s WeMarry</p>
        </header>

        <div class="flex items-start">
          <span class="font-serif text-hero text-ink/80 leading-none md:text-hero-xl">10 000</span>
          <span class="ml-1 mt-2 text-h4 text-ink/80 md:mt-3">Kč</span>
        </div>
        <p class="-mt-4 text-body text-ink-muted">klidně i víc</p>

        <ul class="mt-2 flex flex-col gap-4">
          {
            othersItems.map((label) => (
              <li class="flex items-start gap-3">
                <span aria-hidden="true" class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full border-2 border-[#d97a6c]/70 bg-white">
                  <svg viewBox="0 0 14 14" class="size-3 text-[#d97a6c]" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4L10 10M10 4L4 10"></path></svg>
                </span>
                <span class="text-body text-ink-soft line-through decoration-ink-soft/60">{label}</span>
              </li>
            ))
          }
        </ul>

        <a href={SITE.app.signup} class="btn-outline mt-auto w-full border-primary/50 px-8 py-4 text-primary hover:bg-primary/5">
          Vyzkoušet WeMarry
        </a>
      </article>
    </div>
  </div>
</section>
