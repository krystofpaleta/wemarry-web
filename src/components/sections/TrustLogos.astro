---
import { SITE } from "../../config/site";

const mediaLogos = [
  { name: "Novinky.cz", src: "/img/press/novinky.png" },
  { name: "Svatbona", src: "/img/press/svatbona.png" },
  { name: "Budeme svoji", src: "/img/press/budemesvoji.png" },
  { name: "Fintree", src: "/img/press/fintree.png" },
  { name: "Aha!", src: "/img/press/aha.png" },
];

const ratingValue = String(SITE.rating.value).replace(".", ",");
---

<section class="bg-white py-14 md:py-20">
  <div class="container-site">
    <p class="text-center text-tiny uppercase tracking-cta text-ink-soft">Psali o nás</p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-10 gap-y-6 md:gap-x-16">
      {
        mediaLogos.map((logo) => (
          <img
            src={logo.src}
            alt={logo.name}
            loading="lazy"
            class="h-7 w-auto object-contain opacity-60 grayscale transition hover:opacity-100 hover:grayscale-0 md:h-8"
          />
        ))
      }
    </div>

    <!-- Rating -->
    <div class="mt-10 flex flex-col items-center gap-2">
      <div class="flex items-center gap-1">
        {
          [1, 2, 3, 4, 5].map(() => (
            <svg viewBox="0 0 20 20" class="size-5 text-primary" fill="currentColor" aria-hidden="true">
              <path d="M10 1.5l2.472 5.01 5.528.804-4 3.9.944 5.506L10 14.127 5.056 16.72l.944-5.506-4-3.9 5.528-.804L10 1.5z"></path>
            </svg>
          ))
        }
      </div>
      <p class="flex items-center gap-2 text-small text-ink-muted">
        <img src="/img/google.svg" alt="Google" class="h-4 w-auto" loading="lazy" />
        <a href={SITE.rating.profileUrl} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-ink">
          <span class="font-semibold text-ink">{ratingValue} / 5</span> na základě {SITE.rating.count} recenzí spokojených párů
        </a>
      </p>
    </div>
  </div>
</section>
