---
import { SITE } from "../../config/site";

type FooterCol = { title: string; links: { label: string; href: string }[] };

const columns: FooterCol[] = [
  {
    title: "Produkt",
    links: [
      { label: "Svatební web", href: "/svatebni-web" },
      { label: "Zasedací pořádek", href: "/zasedaci-poradek" },
      { label: "Svatební oznámení", href: "/svatebni-oznameni" },
      { label: "Svatební checklist", href: "/svatebni-checklist" },
      { label: "Svatební rozpočet", href: "/svatebni-rozpocet" },
      { label: "Šablony", href: "/sablony" },
      { label: "Ceník", href: "/cenik" },
    ],
  },
  {
    title: "Pro profesionály",
    links: [
      { label: "Pro koordinátory", href: "/pro-koordinatory" },
    ],
  },
  {
    title: "Společnost",
    links: [
      { label: "O nás", href: "/o-nas" },
      { label: "Blog", href: "/blog" },
      { label: "Kontakt", href: "/kontakt" },
    ],
  },
  {
    title: "Podpora",
    links: [
      { label: "FAQ", href: "/faq" },
      { label: "Obchodní podmínky", href: "/obchodni-podminky" },
      { label: "Ochrana soukromí", href: "/ochrana-soukromi" },
      { label: "Cookies", href: "/cookies" },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="bg-ink text-white">
  <div class="container-site py-16 md:py-20 lg:py-24">
    <!-- Top: brand + newsletter -->
    <div class="grid grid-cols-1 gap-12 border-b border-white/10 pb-12 lg:grid-cols-[1.1fr_1fr] lg:gap-20">
      <div>
        <a href="/" class="font-logo text-h2 italic text-white" aria-label="WeMarry domů">
          WeMarry
        </a>
        <p class="mt-5 max-w-md text-body text-white/70">
          Kompletní svatební plánovač pro české páry. Checklist, rozpočet,
          svatební web, zasedací pořádek a sdílená fotogalerie — vše na jednom
          místě.
        </p>

        <div class="mt-8 flex items-center gap-3">
          <a href={SITE.social.instagram} target="_blank" rel="noreferrer" aria-label="Instagram" class="flex size-10 items-center justify-center rounded-full border border-white/15 bg-white/5 text-white/80 transition-colors hover:border-white/30 hover:bg-white/10 hover:text-white">
            <svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle></svg>
          </a>
          <a href={SITE.social.facebook} target="_blank" rel="noreferrer" aria-label="Facebook" class="flex size-10 items-center justify-center rounded-full border border-white/15 bg-white/5 text-white/80 transition-colors hover:border-white/30 hover:bg-white/10 hover:text-white">
            <svg viewBox="0 0 24 24" class="size-4" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-7.5h2.6l.4-3h-3V8.6c0-.9.3-1.5 1.6-1.5H16.6V4.4c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.4-4 4v2.2H7.8v3h2.4V21h3.3z"></path></svg>
          </a>
          <a href={SITE.social.pinterest} target="_blank" rel="noreferrer" aria-label="Pinterest" class="flex size-10 items-center justify-center rounded-full border border-white/15 bg-white/5 text-white/80 transition-colors hover:border-white/30 hover:bg-white/10 hover:text-white">
            <svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="9"></circle><path d="M11 8c2.5 0 4.5 1.5 4.5 4 0 2.2-1.5 4-3.4 4-1 0-1.8-.5-2.2-1.1"></path><path d="M10 20l2.2-8.8"></path></svg>
          </a>
          <a href={SITE.social.tiktok} target="_blank" rel="noreferrer" aria-label="TikTok" class="flex size-10 items-center justify-center rounded-full border border-white/15 bg-white/5 text-white/80 transition-colors hover:border-white/30 hover:bg-white/10 hover:text-white">
            <svg viewBox="0 0 24 24" class="size-4" fill="currentColor" aria-hidden="true"><path d="M14 3h2.6c.2 1.7 1.3 3 3 3.4V9c-1.2 0-2.4-.4-3.4-1v6.2a4.8 4.8 0 1 1-4.8-4.8c.3 0 .5 0 .8.1v2.6a2.3 2.3 0 1 0 1.8 2.2V3z"></path></svg>
          </a>
        </div>
      </div>

      <!-- Newsletter -->
      <div class="lg:pl-4">
        <p class="text-tiny uppercase tracking-cta text-white/70">Newsletter</p>
        <h3 class="mt-3 font-serif text-h3 text-white">
          Tipy na plánování svatby, rovnou do vašeho mailu.
        </h3>
        <form class="mt-6 flex flex-col gap-3 sm:flex-row" action="/newsletter" method="post">
          <label for="footer-email" class="sr-only">Váš e-mail</label>
          <input id="footer-email" type="email" name="email" required placeholder="vas@email.cz" class="w-full rounded-pill border border-white/15 bg-white/5 px-5 py-3 text-body text-white placeholder:text-white/50 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <button type="submit" class="btn-primary whitespace-nowrap">Přihlásit</button>
        </form>
        <p class="mt-3 text-tiny text-white/50">Odhlásit se můžete jedním kliknutím.</p>
      </div>
    </div>

    <!-- Middle: link columns -->
    <div class="grid grid-cols-2 gap-10 pt-12 md:grid-cols-4">
      {
        columns.map((col) => (
          <div>
            <p class="text-tiny uppercase tracking-cta text-white/70">{col.title}</p>
            <ul class="mt-5 flex flex-col gap-3">
              {col.links.map((link) => (
                <li>
                  <a href={link.href} class="text-body text-white/85 transition-colors hover:text-white">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Platební metody -->
    <div class="mt-12 flex flex-wrap items-center gap-3 border-t border-white/10 pt-8">
      <span class="mr-1 text-tiny uppercase tracking-cta text-white/50">Platba</span>
      {
        ["visa", "mastercard", "applepay", "googlepay", "klarna", "amex"].map((p) => (
          <span class="flex h-7 items-center justify-center rounded-mini bg-white px-2.5">
            <img src={`/img/pay/${p}.svg`} alt={p} class="h-4 w-auto" loading="lazy" />
          </span>
        ))
      }
    </div>

    <!-- Bottom: copyright + legal -->
    <div class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-8 md:flex-row md:items-center">
      <p class="text-small text-white/60">© {year} WeMarry. Všechna práva vyhrazena.</p>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-small text-white/60">
        <a href="/obchodni-podminky" class="hover:text-white">Obchodní podmínky</a>
        <a href="/ochrana-soukromi" class="hover:text-white">Ochrana soukromí</a>
        <a href="/cookies" class="hover:text-white">Cookies</a>
      </div>
    </div>
  </div>
</footer>
