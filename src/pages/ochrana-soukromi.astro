---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalContent from "../components/LegalContent.astro";
import blocks from "../data/legal/ochrana-soukromi.json";

const title = "Ochrana soukromí a zpracování osobních údajů | WeMarry";
const description =
  "Zásady zpracování a ochrany osobních údajů (GDPR) služby WeMarry.";
---

<BaseLayout title={title} description={description}>
  <main class="relative min-h-screen bg-white">
    <section class="container-site pb-24 pt-36 md:pt-44">
      <LegalContent blocks={blocks} />
    </section>
  </main>
</BaseLayout>
