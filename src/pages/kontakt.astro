---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../config/site";

const title = "Kontakt | WeMarry";
const description =
  "Máte dotaz nebo návrh na zlepšení? Ozvěte se týmu WeMarry — odpovídáme do jednoho pracovního dne.";

const phoneDisplay = "608 003 789";
const phoneHref = "tel:+420608003789";
---

<BaseLayout title={title} description={description}>
  <main class="relative min-h-screen bg-white">
    <!-- Hero -->
    <section class="relative isolate overflow-hidden">
      <div aria-hidden="true" class="absolute inset-0 -z-10 bg-gradient-to-br from-sage/30 via-cream to-warm-peach/30"></div>
      <div class="container-site flex min-h-[300px] flex-col items-center justify-center pb-12 pt-40 text-center md:pt-48">
        <p class="mb-4 text-tiny uppercase tracking-cta text-primary">Kontakt</p>
        <h1 class="max-w-2xl font-serif text-hero-sm text-ink md:text-hero">
          Ozvěte se nám
        </h1>
        <p class="mt-5 max-w-xl text-body text-ink-muted">
          Máte dotaz, nebo návrh na novou funkci a zlepšení naší služby? Napište nám —
          odpovídáme do jednoho pracovního dne.
        </p>
      </div>
    </section>

    <section class="container-site py-16 md:py-24">
      <div class="mx-auto grid max-w-4xl grid-cols-1 gap-6 md:grid-cols-2 md:gap-8">
        <!-- E-mail -->
        <a href={`mailto:${SITE.contactEmail}`} class="flex flex-col gap-2 rounded-card border border-beige-border bg-white p-8 shadow-card transition-shadow hover:shadow-prominent">
          <p class="text-tiny uppercase tracking-cta text-primary">E-mail</p>
          <p class="font-serif text-h3 text-ink">{SITE.contactEmail}</p>
          <p class="text-small text-ink-muted">Napište nám kdykoliv, odpovídáme rychle.</p>
        </a>

        <!-- Telefon -->
        <a href={phoneHref} class="flex flex-col gap-2 rounded-card border border-beige-border bg-white p-8 shadow-card transition-shadow hover:shadow-prominent">
          <p class="text-tiny uppercase tracking-cta text-primary">Telefon</p>
          <p class="font-serif text-h3 text-ink">{phoneDisplay}</p>
          <p class="text-small text-ink-muted">Dostupní v pracovní dny.</p>
        </a>
      </div>

      <!-- Fakturační údaje -->
      <div class="mx-auto mt-8 max-w-4xl rounded-card bg-cream p-8">
        <p class="text-tiny uppercase tracking-cta text-ink-soft">Fakturační údaje</p>
        <div class="mt-4 grid grid-cols-1 gap-x-8 gap-y-2 text-body text-ink-body sm:grid-cols-2">
          <p><span class="text-ink-soft">Společnost:</span> WeMarry s.r.o.</p>
          <p><span class="text-ink-soft">IČO:</span> 22269347</p>
          <p class="sm:col-span-2"><span class="text-ink-soft">Sídlo:</span> Hořanská 1510, 130 00 Praha 3</p>
        </div>
      </div>

      <div class="mt-12 flex flex-wrap items-center justify-center gap-4">
        <a href={SITE.app.signup} class="btn-primary">Vyzkoušet zdarma</a>
        <a href={SITE.rating.profileUrl} target="_blank" rel="noopener noreferrer" class="text-micro uppercase tracking-cta text-primary hover:text-primary-hover">
          Najít nás na Googlu →
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
