---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HandsCTA from "../../components/sections/HandsCTA.astro";
import { templates, templateStyles } from "../../data/templates";

const title = "Šablony svatebních webů — WeMarry";
const description =
  "Od minimalismu po květinové romantické vize. Šest designových šablon svatebního webu s RSVP, každá s vlastní atmosférou.";

const filters = ["Vše", ...templateStyles];
---

<BaseLayout title={title} description={description}>
  <main class="relative min-h-screen bg-white">
    <!-- Hero -->
    <section class="relative isolate overflow-hidden">
      <div aria-hidden="true" class="absolute inset-0 -z-10 bg-gradient-to-br from-[#3a2f28] via-[#5a4a40] to-[#8a6a54]"></div>
      <div aria-hidden="true" class="absolute inset-0 -z-10 bg-gradient-to-b from-black/40 via-black/30 to-black/55"></div>

      <div class="container-site flex min-h-[460px] flex-col items-center justify-center pb-16 pt-40 text-center md:min-h-[540px] md:pb-20 md:pt-48">
        <p class="mb-5 text-tiny uppercase tracking-cta text-white/85">Šablony</p>
        <h1 class="max-w-3xl font-serif text-hero-sm italic text-white md:text-hero lg:text-hero-xl">
          Najděte šablonu,
          <span class="not-italic"> která vypadá jako váš den.</span>
        </h1>
        <p class="mt-6 max-w-xl text-body text-white/85">
          Od minimalismu po květinové romantické vize. Šest designových šablon,
          každou vlastní atmosférou, všechny připravené na váš svatební web s RSVP.
        </p>
      </div>
    </section>

    <!-- Filter tabs -->
    <section class="sticky top-0 z-20 border-b border-beige-border bg-white/90 backdrop-blur">
      <div class="container-site">
        <div class="flex flex-wrap items-center gap-2 py-5 md:gap-3 md:py-6">
          {
            filters.map((f, i) => (
              <button
                type="button"
                data-filter={f}
                class:list={[
                  "filter-btn rounded-pill px-4 py-2 text-micro uppercase tracking-cta transition-colors md:px-5 md:py-2.5",
                  i === 0 ? "bg-ink text-white" : "bg-cream text-ink-muted hover:bg-beige-light",
                ]}
              >
                {f}
              </button>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Grid -->
    <section class="relative isolate overflow-hidden py-16 md:py-24 lg:py-28">
      <div class="container-site">
        <div class="mb-8 flex items-end justify-between md:mb-10">
          <p id="count-label" class="text-small text-ink-muted">
            {templates.length} šablon
          </p>
        </div>

        <div id="tpl-grid" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8">
          {
            templates.map((t) => (
              <a
                href={`/sablony/${t.slug}`}
                data-card
                data-style={t.style}
                class="group relative flex aspect-[4/5] flex-col overflow-hidden rounded-card shadow-card transition-all hover:shadow-prominent"
              >
                <div aria-hidden="true" class:list={["absolute inset-0 bg-gradient-to-br", t.palette]}></div>
                <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>

                <div class="relative z-10 flex items-start justify-between p-5 md:p-6">
                  <span class="rounded-pill bg-white/15 px-3 py-1 text-tiny uppercase tracking-cta text-white backdrop-blur-sm">{t.style}</span>
                </div>

                <div class="relative z-10 mt-auto flex flex-col gap-2 p-5 md:p-6">
                  <h3 class="font-serif text-h2 italic text-white md:text-hero-sm">{t.name}</h3>
                  <p class="text-small text-white/85">{t.subtitle}</p>
                  <span class="mt-3 inline-flex items-center gap-2 text-micro uppercase tracking-cta text-white opacity-0 transition-opacity group-hover:opacity-100">
                    Zobrazit náhled →
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <HandsCTA />
  </main>
</BaseLayout>

<script>
  // Filtr šablon — bez Reactu, čistý DOM.
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>("[data-card]");
  const label = document.getElementById("count-label");

  function plural(n: number): string {
    if (n === 1) return "šablona";
    if (n < 5) return "šablony";
    return "šablon";
  }

  function applyFilter(filter: string) {
    let visible = 0;
    cards.forEach((card) => {
      const match = filter === "Vše" || card.dataset.style === filter;
      card.style.display = match ? "" : "none";
      if (match) visible++;
    });
    if (label) {
      label.innerHTML =
        filter === "Vše"
          ? `${visible} ${plural(visible)}`
          : `${visible} ${plural(visible)} ve stylu <strong class="text-ink">${filter}</strong>`;
    }
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      buttons.forEach((b) => {
        b.classList.remove("bg-ink", "text-white");
        b.classList.add("bg-cream", "text-ink-muted", "hover:bg-beige-light");
      });
      btn.classList.add("bg-ink", "text-white");
      btn.classList.remove("bg-cream", "text-ink-muted", "hover:bg-beige-light");
      applyFilter(btn.dataset.filter || "Vše");
    });
  });
</script>
