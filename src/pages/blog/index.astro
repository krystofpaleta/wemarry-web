---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getFeatured, getPopular, getGrid, blogCategories } from "../../lib/blog";

const title = "Svatební blog — WeMarry";
const description =
  "Rady, tipy, inspirace. Vše, co potřebujete vědět před tím, než nastane váš den.";

const featured = await getFeatured();
const popular = await getPopular();
const grid = await getGrid();
---

<BaseLayout title={title} description={description}>
  <main class="relative min-h-screen bg-white">
    <!-- Hero -->
    <section class="relative isolate overflow-hidden">
      <div aria-hidden="true" class="absolute inset-0 -z-10 bg-gradient-to-br from-[#4a3f36] via-[#6b5b52] to-[#3a2f28]"></div>
      <div aria-hidden="true" class="absolute inset-0 -z-10 bg-gradient-to-b from-black/40 via-black/30 to-black/55"></div>

      <div class="container-site flex min-h-[400px] flex-col items-center justify-center pb-16 pt-40 text-center md:min-h-[460px] md:pb-20 md:pt-48">
        <p class="mb-5 text-tiny uppercase tracking-cta text-white/85">Blog</p>
        <h1 class="max-w-3xl font-serif text-hero-sm italic text-white md:text-hero lg:text-hero-xl">Svatební blog</h1>
        <p class="mt-6 max-w-xl text-body text-white/85">Vše, co potřebujete vědět před tím, než nastane váš den.</p>
      </div>
    </section>

    <!-- Featured + Popular -->
    <section class="relative isolate overflow-hidden py-16 md:py-20 lg:py-24">
      <div class="container-site">
        <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1.6fr,1fr] lg:gap-12">
          {
            featured && (
              <a href={`/blog/${featured.slug}`} class="group relative flex aspect-[4/3] flex-col overflow-hidden rounded-card shadow-card transition-all hover:shadow-prominent md:aspect-[16/10]">
                <div aria-hidden="true" class:list={["absolute inset-0 bg-gradient-to-br", featured.data.palette]}></div>
                <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-b from-black/15 via-black/25 to-black/65"></div>

                <div class="relative z-10 p-6 md:p-8">
                  <span class="rounded-pill bg-white/15 px-3 py-1.5 text-tiny uppercase tracking-cta text-white backdrop-blur-sm">{featured.data.category}</span>
                </div>

                <div class="relative z-10 mt-auto p-6 md:p-8">
                  <div class="max-w-md rounded-card bg-white p-6 shadow-prominent md:p-8">
                    <p class="text-tiny uppercase tracking-cta text-ink-soft">{featured.data.date}</p>
                    <h2 class="mt-3 font-serif text-h2 text-ink md:text-hero-sm">{featured.data.title}</h2>
                    <p class="mt-3 line-clamp-3 text-body text-ink-muted">{featured.data.excerpt}</p>
                    <div class="mt-5 flex items-center justify-between">
                      <span class="text-tiny text-ink-soft">{featured.data.readMinutes} min čtení</span>
                      <span class="inline-flex items-center gap-1.5 text-micro uppercase tracking-cta text-primary group-hover:text-primary-hover">Celý článek →</span>
                    </div>
                  </div>
                </div>
              </a>
            )
          }

          <aside class="flex flex-col">
            <h3 class="font-serif text-h2 text-ink md:text-hero-sm">Nejčtenější články</h3>
            <ul class="mt-6 flex flex-col divide-y divide-beige-border">
              {
                popular.map((p) => (
                  <li>
                    <a href={`/blog/${p.slug}`} class="group flex items-center gap-4 py-5 transition-colors">
                      <div aria-hidden="true" class:list={["relative size-20 shrink-0 overflow-hidden rounded-card-sm bg-gradient-to-br", p.data.palette]}>
                        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/30"></div>
                      </div>
                      <div class="flex-1">
                        <p class="text-small font-medium text-ink transition-colors group-hover:text-primary">{p.data.title}</p>
                        <div class="mt-2">
                          <span class="text-tiny text-ink-soft">{p.data.category} · {p.data.readMinutes} min čtení</span>
                        </div>
                      </div>
                    </a>
                  </li>
                ))
              }
            </ul>
          </aside>
        </div>
      </div>
    </section>

    <!-- Kategorie -->
    <section class="relative isolate overflow-hidden bg-cream py-16 md:py-20 lg:py-24">
      <div class="container-site">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-tiny uppercase tracking-cta text-primary">Prohlédněte si</p>
          <h2 class="mt-3 font-serif text-hero-sm text-ink md:text-hero">Kategorie svatebních článků</h2>
        </div>

        <div class="mt-12 -mx-5 md:-mx-10">
          <ul class="flex snap-x snap-mandatory gap-6 overflow-x-auto px-5 pb-4 md:px-10 md:gap-8" role="list">
            {
              blogCategories.map((c) => (
                <li class="flex shrink-0 snap-start flex-col items-center gap-4">
                  <a href={`/blog?kategorie=${encodeURIComponent(c.name)}`} class="group flex flex-col items-center gap-4">
                    <div aria-hidden="true" class:list={["relative size-28 overflow-hidden rounded-full bg-gradient-to-br shadow-card transition-transform group-hover:scale-105 md:size-32", c.palette]}>
                      <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/25"></div>
                    </div>
                    <span class="text-small font-medium text-ink">{c.name}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <!-- Hlavní grid -->
    <section class="relative isolate overflow-hidden py-16 md:py-24 lg:py-28">
      <div class="container-site">
        <div class="mb-10 flex items-end justify-between md:mb-14">
          <div>
            <p class="text-tiny uppercase tracking-cta text-primary">Nejnovější</p>
            <h2 class="mt-3 font-serif text-hero-sm text-ink md:text-hero">Všechny články</h2>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3 lg:gap-10">
          {
            grid.map((p) => (
              <article class="group flex flex-col">
                <a href={`/blog/${p.slug}`} class="relative aspect-[4/3] overflow-hidden rounded-card shadow-card transition-all group-hover:shadow-prominent">
                  <div aria-hidden="true" class:list={["absolute inset-0 bg-gradient-to-br", p.data.palette]}></div>
                  <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/15 to-black/45"></div>
                  <div class="relative p-5 md:p-6">
                    <span class="rounded-pill bg-white/15 px-3 py-1 text-tiny uppercase tracking-cta text-white backdrop-blur-sm">{p.data.category}</span>
                  </div>
                </a>

                <div class="mt-5 flex flex-1 flex-col">
                  <p class="text-tiny uppercase tracking-cta text-ink-soft">{p.data.date} · {p.data.readMinutes} min čtení</p>
                  <h3 class="mt-3 font-serif text-h3 text-ink md:text-h2">
                    <a href={`/blog/${p.slug}`} class="transition-colors hover:text-primary">{p.data.title}</a>
                  </h3>
                  <p class="mt-3 line-clamp-3 text-body text-ink-muted">{p.data.excerpt}</p>
                  <div class="mt-5 flex items-center justify-between border-t border-beige-border pt-4">
                    <span class="text-tiny text-ink-soft">{p.data.readMinutes} min čtení</span>
                    <a href={`/blog/${p.slug}`} class="inline-flex items-center gap-1.5 text-micro uppercase tracking-cta text-primary transition-colors hover:text-primary-hover">Celý článek →</a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>

        <div class="mt-16 flex justify-center">
          <a href="/blog" class="btn-outline" aria-label="Načíst další články">Načíst další</a>
        </div>
      </div>
    </section>

    <!-- Newsletter CTA -->
    <section class="relative isolate overflow-hidden bg-warm-peach/40 py-20 md:py-28">
      <div aria-hidden="true" class="absolute inset-0 -z-10 bg-gradient-to-b from-warm-peach/50 via-cream to-warm-peach/30"></div>
      <div class="container-site">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-tiny uppercase tracking-cta text-primary">Newsletter</p>
          <h2 class="mt-4 font-serif text-hero-sm text-ink md:text-hero">Praktické rady jednou za čas do mailu</h2>
          <p class="mt-4 text-body text-ink-muted">Žádný spam, jen vybrané tipy pro plánování svatby. Odhlásit se můžete kdykoliv jedním kliknutím.</p>

          <form class="mx-auto mt-8 flex max-w-xl flex-col gap-3 sm:flex-row" action="/newsletter" method="post">
            <label class="sr-only" for="newsletter-email">Váš e-mail</label>
            <input id="newsletter-email" type="email" name="email" required placeholder="Zadejte váš e-mail" class="flex-1 rounded-pill border border-beige-border bg-white px-5 py-4 text-body text-ink placeholder:text-ink-light focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30" />
            <button type="submit" class="btn-primary">Odebírat</button>
          </form>

          <p class="mt-5 text-tiny uppercase tracking-cta text-ink-soft">Už nás sleduje přes 3 000 párů</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
